{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Weeknight Table Grocery Product",
  "type": "object",
  "required": [
    "genericIngredient",
    "recommendedProductName",
    "quantityToBuy",
    "category",
    "section",
    "estimatedCost",
    "planningValue",
    "recommendationReason",
    "substitutionRules",
    "confidence"
  ],
  "properties": {
    "genericIngredient": { "type": "string" },
    "recommendedProductName": { "type": "string" },
    "quantityToBuy": { "type": "string" },
    "category": { "enum": ["fresh", "staple", "snack", "household"] },
    "section": { "enum": ["Protein", "Produce", "Dairy", "Bakery", "Dry Goods", "Frozen", "Beverages", "Snacks", "Household", "Other"] },
    "estimatedCost": { "type": "number" },
    "planningValue": { "enum": ["single-use", "shared ingredient", "leftover path", "staple", "backup", "snack"] },
    "tags": { "type": "array", "items": { "type": "string" } },
    "recommendationReason": { "type": "string" },
    "substitutionRules": {
      "type": "object",
      "properties": {
        "preferred": { "type": "array", "items": { "type": "string" } },
        "acceptable": { "type": "array", "items": { "type": "string" } },
        "avoid": { "type": "array", "items": { "type": "string" } }
      }
    },
    "confidence": { "enum": ["ready", "recommended", "needs review"] }
  }
}
