{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rowta.local/schemas/recipe.schema.json",
  "title": "Rowta Recipe",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "revision", "title", "plannerDescription", "overview", "minutes", "activeMinutes", "servings", "ingredientDetails", "ingredientComponentOrder", "stages"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "revision": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    },
    "title": { "type": "string", "minLength": 1 },
    "shortTitle": { "type": "string", "minLength": 1 },
    "plannerDescription": { "type": "string", "minLength": 40, "maxLength": 160, "pattern": "^[A-Z0-9]" },
    "overview": { "type": "string" },
    "minutes": { "type": "number", "minimum": 1 },
    "totalMinutes": { "type": "number", "minimum": 1 },
    "activeMinutes": { "type": "number", "minimum": 0 },
    "servings": { "type": "number", "minimum": 1 },
    "base": { "type": "string" },
    "protein": { "type": "string" },
    "primaryProtein": { "type": "string" },
    "proteins": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "format": { "type": "string" },
    "normalizedBase": { "type": "string" },
    "cuisine": { "type": "string" },
    "difficulty": { "type": "string" },
    "kidFriendly": { "type": "boolean" },
    "goodLeftovers": { "type": "boolean" },
    "pantryFriendly": { "type": "boolean" },
    "lowCleanup": { "type": "boolean" },
    "freezerFriendly": { "type": "boolean" },
    "equipment": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "lastCookedAt": { "type": ["string", "null"] },
    "timesCooked": { "type": "number", "minimum": 0 },
    "familyRating": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
    "repeatCooldownWeeks": { "type": "number", "minimum": 0 },
    "recommendationSignals": { "type": "object" },
    "image": { "type": "string" },
    "imageAlt": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "kidFlex": { "type": "string" },
    "ingredientDetails": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ingredient" }
    },
    "ingredientComponentOrder": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1,
      "uniqueItems": true
    },
    "reusePotential": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "stages": {
      "type": "array",
      "minItems": 2,
      "items": { "$ref": "#/$defs/stage" }
    },
    "sourceLinks": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceLink" }
    },
    "notes": {
      "oneOf": [
        { "type": "string" },
        { "type": "array", "items": { "type": "string" } }
      ]
    },
    "needsReview": { "type": "boolean" }
  },
  "$defs": {
    "ingredient": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "original", "genericIngredient", "quantity", "unit", "section", "component", "optional", "pantryStaple"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "original": { "type": "string", "minLength": 1 },
        "genericIngredient": { "type": "string", "minLength": 1 },
        "quantity": { "type": ["number", "string", "null"] },
        "unit": { "type": "string" },
        "section": { "type": "string" },
        "component": { "type": "string" },
        "optional": { "type": "boolean", "default": false },
        "pantryStaple": {
          "type": "boolean",
          "default": false,
          "description": "True for everyday staples shown separately from the primary shopping ingredients."
        },
        "preferences": {
          "type": "array",
          "items": { "type": "string" }
        },
        "productSearchTerms": {
          "type": "array",
          "items": { "type": "string" }
        },
        "needsReview": { "type": "boolean" }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "durationMinutes", "ingredientUses", "equipment", "actions"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "navTitle": { "type": "string", "minLength": 1 },
        "durationMinutes": { "type": "number", "minimum": 0 },
        "parallelCue": { "type": "string" },
        "ingredientUses": {
          "type": "array",
          "items": { "$ref": "#/$defs/ingredientUse" }
        },
        "equipment": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action" }
        },
        "familyNote": { "type": "string" },
        "familyNoteBeforeActionId": { "type": "string" },
        "safetyNote": { "type": "string" }
      }
    },
    "ingredientUse": {
      "type": "object",
      "additionalProperties": false,
      "required": ["display"],
      "properties": {
        "ingredientId": { "type": "string" },
        "sourceStageId": { "type": "string" },
        "quantity": { "type": ["number", "string", "null"] },
        "unit": { "type": "string" },
        "display": { "type": "string", "minLength": 1 },
        "optional": { "type": "boolean", "default": false },
        "showIfPantry": {
          "type": "boolean",
          "description": "Explicitly keeps a measured or technique-critical pantry staple in this stage's working set."
        }
      },
      "anyOf": [
        { "required": ["ingredientId"] },
        { "required": ["sourceStageId"] }
      ]
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "instruction"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "title": { "type": "string", "minLength": 1 },
        "instruction": { "type": "string", "minLength": 1 },
        "duration": { "$ref": "#/$defs/duration" },
        "heat": { "type": "string" },
        "cue": { "type": "string" },
        "safetyTemperatureF": { "type": "number", "minimum": 32, "maximum": 550 },
        "ingredientRefs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "tip": { "type": "string" }
      }
    },
    "duration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min", "max", "unit"],
      "properties": {
        "min": { "type": "number", "minimum": 0 },
        "max": { "type": "number", "minimum": 0 },
        "unit": { "enum": ["second", "minute", "hour"] }
      }
    },
    "sourceLink": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "url"],
      "properties": {
        "title": { "type": "string" },
        "url": { "type": "string", "format": "uri" },
        "notes": { "type": "string" }
      }
    }
  }
}
